generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String      @id @default(uuid())
  fullName        String
  email           String      @unique
  phone           String?     @unique
  passwordHash    String?
  googleId        String?     @unique
  role            Role        @default(TRADER)
  kycStatus       KycStatus   @default(PENDING)
  aadhaarVerified Boolean     @default(false)
  panNumber       String?
  bankAccount     String?
  bankIfsc        String?
  referralCode    String      @unique
  referredBy      String?
  walletBalance   BigInt      @default(0)
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  challenges      Challenge[]
  payments        Payment[]
  payouts         Payout[]
}

model Plan {
  id             String        @id @default(uuid())
  name           String
  challengeType  ChallengeType @default(ONE_STEP)
  accountSize    BigInt
  challengeFee   BigInt
  profitTarget   Float         @default(0)
  phase2Target   Float         @default(0)
  dailyLossLimit Float
  maxDrawdown    Float
  minTradingDays Int
  maxTradingDays Int
  profitSplit    Float         @default(80)
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  challenges     Challenge[]
}

model Challenge {
  id              String          @id @default(uuid())
  accountNodeId   String?         @unique
  userId          String
  planId          String
  accountSize     BigInt
  currentBalance  BigInt
  peakBalance     BigInt
  totalPnl        BigInt          @default(0)
  dailyPnl        BigInt          @default(0)
  daysTraded      Int             @default(0)
  phase           Int             @default(1)
  status          ChallengeStatus @default(ACTIVE)
  failReason      String?
  startDate       DateTime
  expiryDate      DateTime
  passedAt        DateTime?
  brokerConnected Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  plan            Plan            @relation(fields: [planId], references: [id])
  user            User            @relation(fields: [userId], references: [id])
  payouts         Payout[]
  trades          Trade[]
}

model Trade {
  id            String    @id @default(uuid())
  challengeId   String
  userId        String
  instrument    String
  tradeType     TradeType
  quantity      Int
  entryPrice    BigInt
  exitPrice     BigInt?
  pnl           BigInt    @default(0)
  tradeDate     DateTime
  entryTime     DateTime
  exitTime      DateTime?
  brokerTradeId String?   @unique
  createdAt     DateTime  @default(now())
  challenge     Challenge @relation(fields: [challengeId], references: [id])
}

model Payment {
  id                    String        @id @default(uuid())
  userId                String
  challengeId           String?
  amount                BigInt
  status                PaymentStatus @default(PENDING)
  gstAmount             BigInt        @default(0)
  createdAt             DateTime      @default(now())
  currency              String        @default("usd")
  stripePaymentIntentId String?       @unique
  stripeSessionId       String?       @unique
  user                  User          @relation(fields: [userId], references: [id])
}

model Payout {
  id              String       @id @default(uuid())
  userId          String
  challengeId     String
  amountRequested BigInt
  amountAfterTds  BigInt
  profitSplit     Float
  status          PayoutStatus @default(PENDING)
  adminId         String?
  bankReference   String?
  requestedAt     DateTime     @default(now())
  processedAt     DateTime?
  challenge       Challenge    @relation(fields: [challengeId], references: [id])
  user            User         @relation(fields: [userId], references: [id])
}

enum Role {
  TRADER
  ADMIN
  SUPER_ADMIN
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ChallengeType {
  ZERO_STEP
  ONE_STEP
  TWO_STEP
}

enum ChallengeStatus {
  ACTIVE
  PASSED
  FAILED
  EXPIRED
}

enum TradeType {
  BUY
  SELL
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  APPROVED
  REJECTED
  TRANSFERRED
}
