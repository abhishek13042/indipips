generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String      @id @default(uuid())
  fullName        String
  email           String      @unique
  phone           String?     @unique
  passwordHash    String?
  googleId        String?     @unique
  role            Role        @default(TRADER)
  kycStatus       KycStatus   @default(PENDING)
  aadhaarVerified Boolean     @default(false)
  panNumber       String?
  bankAccount     String?
  bankIfsc        String?
  referralCode    String      @unique
  referredBy      String?
  walletBalance   BigInt      @default(0)
  isActive        Boolean     @default(true)
  brokerAccessToken  String?
  brokerRefreshToken String?
  brokerTokenExpiry  DateTime?
  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?
  emailVerified       Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  challenges      Challenge[]
  payments        Payment[]
  payouts         Payout[]
  notifications   Notification[]
  referrals       User[]      @relation("UserReferrals")
  referrer        User?       @relation("UserReferrals", fields: [referredBy], references: [id])
  emailVerifications EmailVerification[]
  commissionsEarned  AffiliateCommission[] @relation("AffiliateEarned")
}

model Plan {
  id             String        @id @default(uuid())
  name           String
  challengeType  ChallengeType @default(ONE_STEP)
  accountSize    BigInt
  challengeFee   BigInt
  profitTarget   Float         @default(0)
  phase2Target   Float         @default(0)
  dailyLossLimit Float
  maxDrawdown    Float
  minTradingDays Int
  maxTradingDays Int
  profitSplit    Float         @default(80)
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  challenges     Challenge[]
  payments       Payment[]
}

model Challenge {
  id              String          @id @default(uuid())
  accountNodeId   String?         @unique
  userId          String
  planId          String
  accountSize     BigInt
  currentBalance  BigInt
  peakBalance     BigInt
  dailyStartingBalance BigInt?
  totalPnl        BigInt          @default(0)
  dailyPnl        BigInt          @default(0)
  daysTraded      Int             @default(0)
  phase           Int             @default(1)
  status          ChallengeStatus @default(ACTIVE)
  failReason      String?
  startDate       DateTime
  expiryDate      DateTime
  passedAt        DateTime?
  totalTrades     Int             @default(0)
  winCount        Int             @default(0)
  lossCount       Int             @default(0)
  brokerConnected Boolean         @default(false)
  isLive          Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  plan            Plan            @relation(fields: [planId], references: [id])
  user            User            @relation(fields: [userId], references: [id])
  payouts         Payout[]
  trades          Trade[]
  equitySnapshots EquitySnapshot[]
}

model Trade {
  id            String      @id @default(uuid())
  challengeId   String
  userId        String
  symbol        String
  tradeType     TradeType
  quantity      Int
  entryPrice    BigInt
  exitPrice     BigInt?
  pnl           BigInt      @default(0)
  status        TradeStatus @default(OPEN)
  entryTime     DateTime    @default(now())
  exitTime      DateTime?
  brokerTradeId String?     @unique
  createdAt     DateTime    @default(now())
  challenge     Challenge   @relation(fields: [challengeId], references: [id])
}

model Payment {
  id                    String        @id @default(uuid())
  userId                String
  challengeId           String?
  amount                BigInt
  status                PaymentStatus @default(PENDING)
  gstAmount             BigInt        @default(0)
  createdAt             DateTime      @default(now())
  currency              String        @default("usd")
  stripePaymentIntentId String?       @unique
  stripeSessionId       String?       @unique
  razorpayOrderId       String?       @unique
  razorpayPaymentId     String?       @unique
  planId                String?
  plan                  Plan?         @relation(fields: [planId], references: [id])
  user                  User          @relation(fields: [userId], references: [id])
}

model Payout {
  id              String       @id @default(uuid())
  userId          String
  challengeId     String
  amountRequested BigInt
  amountAfterTds  BigInt
  profitSplit     Float
  status          PayoutStatus @default(PENDING)
  adminId         String?
  bankReference   String?
  requestedAt     DateTime     @default(now())
  processedAt     DateTime?
  challenge       Challenge    @relation(fields: [challengeId], references: [id])
  user            User         @relation(fields: [userId], references: [id])
}

enum Role {
  TRADER
  ADMIN
  SUPER_ADMIN
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ChallengeType {
  ZERO_STEP
  ONE_STEP
  TWO_STEP
}

enum ChallengeStatus {
  ACTIVE
  PASSED
  FAILED
  EXPIRED
}

enum TradeType {
  BUY
  SELL
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  APPROVED
  REJECTED
  TRANSFERRED
}

enum TradeStatus {
  OPEN
  CLOSED
}

model EquitySnapshot {
  id          String    @id @default(uuid())
  challengeId String
  balance     BigInt
  equity      BigInt
  timestamp   DateTime  @default(now())
  challenge   Challenge @relation(fields: [challengeId], references: [id])
}

model AuditLog {
  id              String   @id @default(uuid())
  userId          String
  action          String
  amount          BigInt?
  previousBalance BigInt?
  newBalance      BigInt?
  ipAddress       String?
  metadata        Json?
  createdAt       DateTime @default(now())
}

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // "BREACH", "PAYOUT", "KYC", "WELCOME"
  title     String
  body      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model AffiliateCommission {
  id            String   @id @default(uuid())
  affiliateId   String   // The user who earned it
  referredUserId String   // The user who made the purchase
  challengeId   String   // The challenge purchase that triggered it
  amount        BigInt   // Commission in paise
  status        String   @default("PENDING") // PENDING, PAID, REJECTED
  createdAt     DateTime @default(now())
  affiliate     User     @relation("AffiliateEarned", fields: [affiliateId], references: [id])
}
